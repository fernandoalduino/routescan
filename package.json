{
  "name": "routescan",
  "version": "0.1.0",
  "description": "Static analysis CLI that scans Express projects and documents their routes.",
  "keywords": ["express", "routes", "cli", "documentation", "ast", "static-analysis"],
  "license": "MIT",
  "main": "dist/index.js",
  "bin": {
    "routescan": "dist/cli.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0",
    "vitest": "^1.3.0"
  },
  "dependencies": {
    "ts-morph": "^21.0.1"
  }
}